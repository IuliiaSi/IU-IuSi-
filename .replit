modules = ["web", "nodejs-20"]
[agent]
expertMode = true
integrations = ["javascript_openai_ai_integrations:2.0.0"]

[nix]
channel = "stable-25_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd \"Lectures&HW/projects/AntiScam/backend\" && ([ -d node_modules ] || npm install) && ([ -f dist/main.js ] || npm run build) && ([ -d ../frontend/dist ] || (cd ../frontend && ([ -d node_modules ] || npm install) && npm run build)) && npm run start:prod"
waitForPort = 3000

[workflows.workflow.metadata]
outputType = "webview"

[[ports]]
localPort = 3000
externalPort = 80

[deployment]
deploymentTarget = "autoscale"
run = ["sh", "-c", "cd \"Lectures&HW/projects/AntiScam/backend\" && ([ -d node_modules ] || npm install) && ([ -f dist/main.js ] || npm run build) && ([ -d ../frontend/dist ] || (cd ../frontend && ([ -d node_modules ] || npm install) && npm run build)) && npm run start:prod"]
