modules = ["web", "nodejs-20"]
[agent]
expertMode = true
integrations = ["javascript_openai_ai_integrations:2.0.0"]

[nix]
channel = "stable-25_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "([ -n \"$SUPABASE_URL\" ] && [ -n \"$SUPABASE_ANON_KEY\" ] && [ -n \"$VITE_SUPABASE_URL\" ] && [ -n \"$VITE_SUPABASE_ANON_KEY\" ] || (echo \"Missing env: SUPABASE_URL, SUPABASE_ANON_KEY, VITE_SUPABASE_URL, VITE_SUPABASE_ANON_KEY\" && exit 1)) && cd \"Lectures&HW/projects/AntiScam/frontend\" && ([ -d node_modules ] || npm install) && npm run build && cd ../backend && ([ -d node_modules ] || npm install) && ([ -f dist/main.js ] || npm run build) && npm run start:prod"
waitForPort = 3000

[workflows.workflow.metadata]
outputType = "webview"

[[ports]]
localPort = 3000
externalPort = 80

[deployment]
deploymentTarget = "autoscale"
run = ["sh", "-c", "([ -n \"$SUPABASE_URL\" ] && [ -n \"$SUPABASE_ANON_KEY\" ] && [ -n \"$VITE_SUPABASE_URL\" ] && [ -n \"$VITE_SUPABASE_ANON_KEY\" ] || (echo \"Missing env: SUPABASE_URL, SUPABASE_ANON_KEY, VITE_SUPABASE_URL, VITE_SUPABASE_ANON_KEY\" && exit 1)) && cd \"Lectures&HW/projects/AntiScam/frontend\" && ([ -d node_modules ] || npm install) && npm run build && cd ../backend && ([ -d node_modules ] || npm install) && ([ -f dist/main.js ] || npm run build) && npm run start:prod"]
